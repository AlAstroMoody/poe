{
  "name": "poe",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "build:dict": "node scripts/build-stat-dict.mjs",
    "fetch:passive-tree-ru": "node scripts/fetch-passive-tree-ru.mjs",
    "fetch:alternate-names": "node scripts/fetch-alternate-passive-names-ru.mjs",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "deploy": "npm run version:patch && npm run build && git add dist package.json -f && git commit -m \"Deploy v$(node -p \"require('./package.json').version\")\" && git subtree push --prefix dist origin gh-pages",
    "fetch:skilltree-export": "node scripts/fetch-skilltree-export.mjs",
    "prepare:wasm-data": "node scripts/prepare-wasm-data.mjs",
    "pipeline:refresh": "npm run fetch:go-pob-data && npm run fetch:skilltree-export && npm run fetch:passive-tree-ru && npm run build:dict && npm run prepare:wasm-data && npm run wasm:build && npm run release:check",
    "wasm:build": "bash scripts/build-wasm.sh",
    "fetch:go-pob-data": "node scripts/fetch-go-pob-data.mjs",
    "extract:go-pob-copy": "node scripts/extract-go-pob-data-local.mjs",
    "extract:go-pob-run": "bash scripts/run-go-pob-data-extract.sh",
    "convert:legion-passives": "node scripts/convert-legion-passives-from-pob.mjs",
    "extract:pob-legion-display": "node scripts/extract-alternate-passive-display-pob.mjs",
    "import:pypoe-bundle": "node scripts/import-pypoe-dat-bundle.mjs",
    "fetch:stat-translations-ggpk": "bash scripts/fetch-repoe-stat-translations-from-ggpk.sh",
    "pipeline:refresh:full": "npm run pipeline:refresh && npm run fetch:alternate-names && npm run build:dict && npm run release:check",
    "release:check": "node scripts/release-check.mjs",
    "format": "oxfmt src scripts vite.config.ts",
    "format:check": "oxfmt --check src scripts vite.config.ts",
    "lint": "oxlint src scripts vite.config.ts",
    "lint:fix": "oxlint --fix src scripts vite.config.ts"
  },
  "dependencies": {
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.13",
    "vue-tsc": "^3.2.9"
  }
}
